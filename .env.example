# OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Spotify Developer Credentials
# Create an app at: https://developer.spotify.com/dashboard
# IMPORTANT: Add https://localhost/callback as a redirect URI in your Spotify app settings
SPOTIPY_CLIENT_ID=your_client_id
SPOTIPY_CLIENT_SECRET=your_client_secret

# Your Spotify username (playlists will be created on this account)
SPOTIFY_USER=your_spotify_username

# Resend API Key (optional)
# Get yours at: https://resend.com/api-keys
# If not set, email sending will be skipped
RESEND_API_KEY=re_your-api-key-here
